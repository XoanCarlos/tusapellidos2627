<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane fx:id="rootPane" prefHeight="100.0" prefWidth="180.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.clase.MainController">

    <top>

        <HBox alignment="CENTER" spacing="10">

            <Button onAction="#mostrarClientes" text="Clientes" />

            <Button onAction="#mostrarProductos" text="Productos" />
                <padding>
                     <Insets top="20.0" />
                </padding>

        </HBox>

    </top>

    <center>

        <Label text="Bienvenido al sistema" />

    </center>

</BorderPane>
